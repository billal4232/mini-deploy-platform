# Terraform state — NEVER commit
*.tfstate
*.tfstate.*

# Terraform working directory
.terraform/

# Override files (may contain secrets)
*.tfvars
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Crash logs
crash.log
crash.*.log

# Lambda build artifact
lambda/*.zip

# CLI config
.terraformrc
terraform.rc
